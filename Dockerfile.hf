FROM python:3.12-slim

WORKDIR /app

# Install build deps for socksio, then clean up
RUN apt-get update && apt-get install -y --no-install-recommends gcc python3-dev && rm -rf /var/lib/apt/lists/*

# HuggingFace Spaces 要求创建 user (UID 1000)
RUN useradd -m -u 1000 user

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt "httpx[socks]"

COPY gemini_web2api/ ./gemini_web2api/
COPY gemini_web2api.py ./

# HF Spaces 默认端口为 7860
COPY config.example.json ./config.json
RUN sed -i 's/"port": 8081/"port": 7860/' config.json && \
    sed -i 's/"host": "0.0.0.0"/"host": "0.0.0.0"/' config.json

RUN chown -R user:user /app && chmod -R 777 /app

USER user
ENV HOME=/home/user
ENV PYTHONUNBUFFERED=1

EXPOSE 7860

# 显式指定 host 为 0.0.0.0 确保外部可访问
CMD ["python", "-m", "gemini_web2api", "--config", "/app/config.json", "--port", "7860"]
